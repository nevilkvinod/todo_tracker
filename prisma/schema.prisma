datasource db {
  provider = "postgresql"
}

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

// NextAuth Required Models (Retained for completeness/PrismaAdapter)
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum Role {
  USER
  MANAGER
}

enum ProjectStatus {
  ACTIVE
  ON_HOLD
  CANCELLED
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String
  emailVerified DateTime?
  password      String?
  image         String?
  role          Role      @default(USER)

  accounts      Account[]
  sessions      Session[]
  tasks         Task[]    @relation("AssignedTasks")
  userProjects  UserProject[]
  auditLogs     AuditLog[]
  loginActivities LoginActivity[]
  comments      Comment[]
  taskHistory   TaskHistory[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
}

model Project {
  id          String    @id @default(cuid())
  name        String
  description String?
  color       String        @default("#4F46E5")
  status      ProjectStatus @default(NOT_STARTED)
  
  tasks       Task[]
  userProjects UserProject[]
  
  deletedAt   DateTime?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([deletedAt])
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  status      TaskStatus @default(TODO)
  order       Float
  priority    String     @default("Medium") // Critical, High, Medium, Low
  completionPercentage Int @default(0)
  startDate   DateTime?
  endDate     DateTime?
  dueDate     DateTime?
  
  projectId   String
  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  assigneeId  String?
  assignee    User?      @relation("AssignedTasks", fields: [assigneeId], references: [id], onDelete: SetNull)
  
  subtasks    Subtask[]
  comments    Comment[]
  history     TaskHistory[]

  deletedAt   DateTime?

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([projectId, status])
  @@index([assigneeId])
  @@index([deletedAt])
}

model Subtask {
  id          String   @id @default(cuid())
  title       String
  isCompleted Boolean  @default(false)
  order       Float    @default(0)
  
  taskId      String
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([taskId])
}

model Comment {
  id        String   @id @default(cuid())
  content   String   @db.Text
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([taskId])
  @@index([userId])
}

model TaskHistory {
  id        String   @id @default(cuid())
  field     String   // e.g. "status", "assignee", "title"
  oldValue  String?  @db.Text
  newValue  String?  @db.Text
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())

  @@index([taskId])
  @@index([userId])
}

model UserProject {
  id        String   @id @default(cuid())
  userId    String
  projectId String
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, projectId])
  @@index([userId])
  @@index([projectId])
  @@index([createdAt])
}

model AuditLog {
  id          String   @id @default(cuid())
  action      String
  userId      String
  targetId    String?
  targetEmail String?
  metadata    Json?
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model LoginActivity {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  loginAt   DateTime @default(now())
  logoutAt  DateTime?
  duration  Int?     // in minutes
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([loginAt])
}
